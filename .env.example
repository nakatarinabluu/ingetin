# --- PROJECT CONFIG ---
PROJECT_NAME=ingetin
NODE_ENV=development
PORT=4000

# --- DATABASE (Postgres) ---
POSTGRES_USER=ingetin_sys_admin
POSTGRES_PASSWORD=YOUR_SECURE_PASSWORD_HERE
POSTGRES_DB=ingetin_whatsapp_db
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@ingetin-db:5432/${POSTGRES_DB}?schema=public

# --- CACHE (Redis) ---
REDIS_PASSWORD=YOUR_SECURE_PASSWORD_HERE
REDIS_URL=redis://default:${REDIS_PASSWORD}@ingetin-redis:6379

# --- CLOUDFLARE TUNNEL ---
CLOUDFLARE_TUNNEL_TOKEN=your_token_here
VITE_API_URL=https://api.yourdomain.com
FRONTEND_URL=https://app.yourdomain.com

# --- WHATSAPP CONFIG ---
WA_OTP_PHONE_NUMBER_ID=YOUR_PHONE_NUMBER_ID
WA_OTP_ACCESS_TOKEN=YOUR_ACCESS_TOKEN
WA_NOTIF_PHONE_NUMBER_ID=YOUR_PHONE_NUMBER_ID
WA_NOTIF_ACCESS_TOKEN=YOUR_ACCESS_TOKEN
WA_BUSINESS_ACCOUNT_ID=YOUR_BUSINESS_ACCOUNT_ID
WA_VERIFY_TOKEN=your_secret_verify_token
WA_APP_SECRET=YOUR_META_APP_SECRET

# --- GOOGLE OAUTH ---
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_REDIRECT_URI=https://your-domain.com/api/auth/google/callback

# --- SECURITY & OTHERS ---
JWT_SECRET=your_jwt_secret_key
JWT_ACCESS_SECRET=your_jwt_access_secret
JWT_REFRESH_SECRET=your_jwt_refresh_secret
ENCRYPTION_SECRET=your_64_char_hex_encryption_secret
MY_PERSONAL_PHONE=628...
FRONTEND_URL=https://your-domain.com/app
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4000,https://your-domain.com

# --- MONITORING (Optional) ---
OTEL_ENABLED=false
SENTRY_DSN=your_sentry_dsn
